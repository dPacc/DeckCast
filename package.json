{
  "name": "deckcast",
  "version": "1.0.0",
  "description": "Share Steam Deck recordings — Wi-Fi transfer, YouTube upload, clip trimming, and live streaming from Gaming Mode",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dPacc/DeckCast"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^24.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rollup": "^4.9.4",
    "rollup-plugin-import-css": "^3.5.0",
    "shx": "^0.3.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "@decky/ui": "^4.7.2",
    "react-icons": "^5.0.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
